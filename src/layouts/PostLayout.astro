---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  collection: string;
  showDate?: boolean;
  ogType?: string;
  ogImage?: string;
  jsonLd?: string;
}

const { title, description, date, collection, showDate = true, ogType, ogImage, jsonLd } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const collectionLabel = collection.replace(/-/g, ' ');
---
<BaseLayout title={`${title} — Joy4Wine | Wine in Málaga`} description={description} ogType={ogType} ogImage={ogImage} jsonLd={jsonLd}>
  <article class="post">
    <div class="container--narrow">
      <nav class="post-breadcrumb" aria-label="Breadcrumb">
        <a href={`/${collection}/`}>{collectionLabel}</a>
        <span style="margin: 0 0.4rem; color: var(--color-border);">/</span>
        <span style="color: var(--color-text-muted);">{title}</span>
      </nav>
      <h1 class="post-title">{title}</h1>
      <slot name="meta" />
      {showDate && <time class="post-date" datetime={date.toISOString()}>{formattedDate}</time>}
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
