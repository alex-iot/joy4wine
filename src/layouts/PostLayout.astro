---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  collection: string;
}

const { title, description, date, collection } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const collectionLabel = collection.replace(/-/g, ' ');
---
<BaseLayout title={`${title} — Joy4Wine`} description={description}>
  <article class="post">
    <div class="container--narrow">
      <nav class="post-breadcrumb" aria-label="Breadcrumb">
        <a href={`/${collection}/`}>{collectionLabel}</a>
        <span style="margin: 0 0.4rem; color: var(--color-border);">/</span>
        <span style="color: var(--color-text-muted);">{title}</span>
      </nav>
      <h1 class="post-title">{title}</h1>
      <slot name="meta" />
      <time class="post-date" datetime={date.toISOString()}>{formattedDate}</time>
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
