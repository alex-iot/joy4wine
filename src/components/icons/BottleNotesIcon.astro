  <path d="M8.5 3 Q8.5 9.5 12 12 Q15.5 9.5 15.5 3 Z" fill="#FFF" stroke="#C4A882" stroke-width="1" stroke-linejoin="round"/>
  <rect x="7" y="8" width="10" height="5" fill="#8B2635" clip-path="url(#bowl-clip)"/>
  <line x1="12" y1="12" x2="12" y2="19.5" stroke="#C4A882" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="9.5" y1="19.5" x2="14.5" y2="19.5" stroke="#C4A882" stroke-width="1.2" stroke-linecap="round"/>
  <path d="M8.5 3 Q8.5 9.5 12 12 Q15.5 9.5 15.5 3 Z" fill="none" stroke="#C4A882" stroke-width="1" stroke-linejoin="round"/>
