---
const navLinks = [
  { href: '/wine-shops/', label: 'Wine Shops' },
  { href: '/wineries/', label: 'Wineries' },
  { href: '/guides/', label: 'Guides' },
  { href: '/bottle-notes/', label: 'Bottle Notes' },
  { href: '/about/', label: 'About' },
  { href: '/newsletter/', label: 'Newsletter' },
];
---
<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <a href="/" class="logo">
        <span class="logo-text">joy<span class="logo-four">4</span>wine</span>
        <span class="logo-tagline">Málaga &amp; Costa del Sol</span>
      </a>
      <ul class="footer-links">
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
      <div class="footer-social">
        <p style="margin:0 0 0.5rem; color: var(--color-accent-muted);">Follow along</p>
        <a href="https://instagram.com/joy.4.wine" target="_blank" rel="noopener noreferrer">
          @joy.4.wine on Instagram
        </a>
      </div>
    </div>
    <div class="footer-bottom">
      <p style="margin:0;">© {new Date().getFullYear()} Joy4Wine. A personal guide to wine in Málaga.</p>
    </div>
  </div>
</footer>
