---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('wineries', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const siteUrl = (Astro.site?.toString() ?? 'https://joy4wine.com').replace(/\/$/, '');
const pageUrl = `${siteUrl}/wineries/${entry.slug}/`;
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Winery',
      name: entry.data.title,
      description: entry.data.subtitle,
      address: {
        '@type': 'PostalAddress',
        addressRegion: entry.data.region,
        addressCountry: 'ES',
      },
      url: pageUrl,
      ...(entry.data.image ? { image: `${siteUrl}${entry.data.image}` } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Wineries & Producers', item: `${siteUrl}/wineries/` },
        { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
      ],
    },
  ],
});
---
<PostLayout
  title={entry.data.title}
  description={entry.data.subtitle}
  date={entry.data.date}
  collection="wineries"
  ogImage={entry.data.image}
  jsonLd={jsonLd}
>
  <Fragment slot="meta">
    <p class="post-subtitle">{entry.data.subtitle}</p>
    <div class="post-meta">
      <span class="post-meta-label">Region</span>
      <span class="post-meta-value">{entry.data.region}</span>
      <span class="post-meta-label">Grapes</span>
      <span class="post-meta-value">{entry.data.grapes}</span>
      <span class="post-meta-label">Price range</span>
      <span class="post-meta-value">{entry.data.price_range}</span>
    </div>
  </Fragment>
  <Content />
</PostLayout>
