---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuidesIcon from '../../components/icons/GuidesIcon.astro';

const guides = (await getCollection('guides', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout
  title="Guides — Joy4Wine"
  description="Practical guides to buying, tasting, and understanding wine in Málaga."
>
  <div class="page-header">
    <div class="container">
      <h1 class="page-header-title"><div class="page-header-icon" style="background:#E4EEE8"><GuidesIcon width={28} height={28} /></div>Guides</h1>
      <p>Practical guides to buying, tasting, and understanding wine in Málaga and the Costa del Sol.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {guides.length > 0 ? (
        <div class="post-list">
          {guides.map(guide => (
            <a href={`/guides/${guide.slug}/`} class="post-item">
              <div class="post-item-header">
                <h2 class="post-item-title">{guide.data.title}</h2>
                <span class="badge">{guide.data.topic}</span>
              </div>
              <p class="post-item-subtitle">{guide.data.subtitle}</p>
              <div class="post-item-meta">
                <span>{guide.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Guides are on the way. Check back soon.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
