---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuidesIcon from '../../components/icons/GuidesIcon.astro';

const guides = (await getCollection('guides', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout
  title="Guides — Joy4Wine | Wine in Málaga"
  description="Practical guides to buying, tasting, and understanding wine in Málaga and the Costa del Sol."
>
  <div class="page-header">
    <div class="container">
      <h1 class="page-header-title"><div class="page-header-icon" style="background:#E4EEE8"><GuidesIcon width={28} height={28} /></div>Guides</h1>
      <p>Practical guides to buying, tasting, and understanding wine in Málaga and the Costa del Sol.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {guides.length > 0 ? (
        <div class="post-list">
          {guides.map(guide => (
            <a href={`/guides/${guide.slug}/`} class="post-item">
              <div class="post-item-header">
                <h2 class="post-item-title">{guide.data.title}</h2>
              </div>
              <p class="post-item-subtitle">{guide.data.subtitle}</p>
              <div class="post-item-meta">
                <span>{guide.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <div class="guide-index-topics">
                  {guide.data.topic.split(',').map((t: string) => (
                    <span class="guide-index-topic">{t.trim()}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Guides are on the way. Check back soon.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .guide-index-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .guide-index-topic {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-bg);
    border: 0.5px solid var(--color-border);
    padding: 0.25rem 0.625rem;
    border-radius: 2px;
  }
</style>
