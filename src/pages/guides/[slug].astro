---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('guides', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const topics = entry.data.topic.split(',').map((t: string) => t.trim()).filter(Boolean);

const siteUrl = (Astro.site?.toString() ?? 'https://joy4wine.com').replace(/\/$/, '');
const pageUrl = `${siteUrl}/guides/${entry.slug}/`;
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: entry.data.title,
      description: entry.data.subtitle,
      datePublished: entry.data.date.toISOString(),
      author: {
        '@type': 'Person',
        name: 'Joy4Wine',
        url: `${siteUrl}/about/`,
      },
      publisher: {
        '@type': 'Organization',
        name: 'Joy4Wine',
        url: siteUrl,
      },
      url: pageUrl,
      ...(entry.data.image ? { image: `${siteUrl}${entry.data.image}` } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Guides', item: `${siteUrl}/guides/` },
        { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
      ],
    },
  ],
});
---
<PostLayout
  title={entry.data.title}
  description={entry.data.subtitle}
  date={entry.data.date}
  collection="guides"
  ogType="article"
  ogImage={entry.data.image}
  jsonLd={jsonLd}
>
  <Fragment slot="meta">
    <p class="post-subtitle">{entry.data.subtitle}</p>
  </Fragment>
  <Content />
  {topics.length > 0 && (
    <div class="guide-tags-footer">
      <span class="guide-meta-label">Filed under</span>
      <div class="guide-tags">
        {topics.map(t => <span class="guide-tag">{t}</span>)}
      </div>
    </div>
  )}
</PostLayout>

<style>
  .guide-tags-footer {
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    margin-top: 2rem;
  }

  .guide-meta-label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .guide-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .guide-tag {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-bg);
    border: 0.5px solid var(--color-border);
    padding: 0.25rem 0.625rem;
    border-radius: 2px;
  }
</style>
