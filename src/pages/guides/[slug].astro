---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('guides', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const siteUrl = (Astro.site?.toString() ?? 'https://joy4wine.com').replace(/\/$/, '');
const pageUrl = `${siteUrl}/guides/${entry.slug}/`;
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: entry.data.title,
      description: entry.data.subtitle,
      datePublished: entry.data.date.toISOString(),
      author: {
        '@type': 'Person',
        name: 'Joy4Wine',
        url: `${siteUrl}/about/`,
      },
      publisher: {
        '@type': 'Organization',
        name: 'Joy4Wine',
        url: siteUrl,
      },
      url: pageUrl,
      ...(entry.data.image ? { image: `${siteUrl}${entry.data.image}` } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Guides', item: `${siteUrl}/guides/` },
        { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
      ],
    },
  ],
});
---
<PostLayout
  title={entry.data.title}
  description={entry.data.subtitle}
  date={entry.data.date}
  collection="guides"
  ogType="article"
  ogImage={entry.data.image}
  jsonLd={jsonLd}
>
  <Fragment slot="meta">
    <p class="post-subtitle">{entry.data.subtitle}</p>
    <div class="post-meta">
      <span class="post-meta-label">Topic</span>
      <span class="post-meta-value">{entry.data.topic}</span>
    </div>
  </Fragment>
  <Content />
</PostLayout>
