---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Newsletter — Joy4Wine | Wine in Málaga"
  description="Subscribe to Joy4Wine for honest wine shop reviews, bottle notes, and guides from Málaga and the Costa del Sol."
>
  <div class="page-header">
    <div class="container--narrow">
      <h1>Subscribe to Joy4Wine</h1>
      <p>Honest notes from Málaga, delivered to your inbox when there's something worth sharing.</p>
    </div>
  </div>

  <section class="section">
    <div class="container--narrow">
      <p style="color:var(--color-text-secondary); max-width:52ch;">
        I send occasional emails when I've visited a wine shop worth knowing about, tasted a
        bottle I want to tell people about, or written a guide that might be genuinely useful.
        No frequency commitments — just quality over quantity.
      </p>
      <p style="color:var(--color-text-secondary); max-width:52ch;">
        No spam. No selling your data. Unsubscribe at any time.
      </p>

      <form class="newsletter-form js-newsletter-form" style="margin-top:2.5rem;">
        <input
          class="newsletter-input"
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          aria-label="Email address"
          style="background: var(--color-bg-white); color: var(--color-text-primary); border-color: var(--color-border);"
        />
        <button type="submit" class="btn btn--primary">Subscribe</button>
      </form>
    </div>
  </section>

<script>
  import '../scripts/newsletter-form.ts';
</script>
</BaseLayout>
