---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Newsletter — Joy4Wine"
  description="Subscribe to Joy4Wine for wine shop reviews, bottle notes, and guides from Málaga."
>
  <div class="page-header">
    <div class="container--narrow">
      <h1>Subscribe to Joy4Wine</h1>
      <p>Honest notes from Málaga, delivered to your inbox when there's something worth sharing.</p>
    </div>
  </div>

  <section class="section">
    <div class="container--narrow">
      <p style="color:var(--color-text-secondary); max-width:52ch;">
        I send occasional emails when I've visited a wine shop worth knowing about, tasted a
        bottle I want to tell people about, or written a guide that might be genuinely useful.
        No frequency commitments — just quality over quantity.
      </p>
      <p style="color:var(--color-text-secondary); max-width:52ch;">
        No spam. No selling your data. Unsubscribe at any time.
      </p>

      <!-- Placeholder: replace with MailerLite embed -->
      <div style="margin-top:2.5rem; padding:2rem; border:1px solid var(--color-border); border-radius:8px; background:var(--color-bg-warm);">
        <p style="color:var(--color-text-muted); font-size:0.875rem; margin:0;">
          Newsletter signup form will appear here once connected to MailerLite.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
