---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('bottle-notes', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const siteUrl = (Astro.site?.toString() ?? 'https://joy4wine.com').replace(/\/$/, '');
const pageUrl = `${siteUrl}/bottle-notes/${entry.slug}/`;
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Review',
      name: entry.data.title,
      datePublished: entry.data.date.toISOString(),
      author: {
        '@type': 'Person',
        name: 'Joy4Wine',
        url: `${siteUrl}/about/`,
      },
      itemReviewed: {
        '@type': 'Product',
        name: entry.data.title,
        brand: {
          '@type': 'Brand',
          name: entry.data.producer,
        },
      },
      url: pageUrl,
      ...(entry.data.image ? { image: `${siteUrl}${entry.data.image}` } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Bottle Notes', item: `${siteUrl}/bottle-notes/` },
        { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
      ],
    },
  ],
});
---
<PostLayout
  title={entry.data.title}
  description={`${entry.data.producer} · ${entry.data.grape} · ${entry.data.vintage}`}
  date={entry.data.date}
  collection="bottle-notes"
  ogType="article"
  ogImage={entry.data.image}
  jsonLd={jsonLd}
>
  <Fragment slot="meta">
    <div class="post-meta">
      <span class="post-meta-label">Producer</span>
      <span class="post-meta-value">{entry.data.producer}</span>
      <span class="post-meta-label">Region</span>
      <span class="post-meta-value">{entry.data.region}</span>
      <span class="post-meta-label">Grape</span>
      <span class="post-meta-value">{entry.data.grape}</span>
      <span class="post-meta-label">Vintage</span>
      <span class="post-meta-value">{entry.data.vintage}</span>
      <span class="post-meta-label">Price (approx)</span>
      <span class="post-meta-value">{entry.data.price_approx}</span>
    </div>
  </Fragment>
  <Content />
</PostLayout>
