---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('wine-shops', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = entry.data.date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const hasTags = entry.data.tags && entry.data.tags.length > 0;

const siteUrl = (Astro.site?.toString() ?? 'https://joy4wine.com').replace(/\/$/, '');
const pageUrl = `${siteUrl}/wine-shops/${entry.slug}/`;
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      name: entry.data.title,
      description: entry.data.subtitle,
      address: {
        '@type': 'PostalAddress',
        addressLocality: entry.data.location,
        addressCountry: 'ES',
      },
      url: pageUrl,
      ...(entry.data.image ? { image: `${siteUrl}${entry.data.image}` } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Wine Shops', item: `${siteUrl}/wine-shops/` },
        { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
      ],
    },
  ],
});
---
<PostLayout
  title={entry.data.title}
  description={entry.data.subtitle}
  date={entry.data.date}
  collection="wine-shops"
  showDate={false}
  ogImage={entry.data.image}
  jsonLd={jsonLd}
>
  <Fragment slot="meta">
    <p class="post-subtitle">{entry.data.subtitle}</p>
    <p class="shop-date">{formattedDate}</p>
    <div class="shop-meta">
      <div class="shop-meta-field">
        <span class="shop-meta-label">Location</span>
        <span class="shop-meta-value">{entry.data.location}</span>
      </div>
      <div class="shop-meta-field">
        <span class="shop-meta-label">Best for</span>
        <span class="shop-meta-value">{entry.data.best_for}</span>
      </div>
    </div>
  </Fragment>
  <Content />
  {hasTags && (
    <div class="shop-tags-footer">
      <span class="shop-meta-label">Filed under</span>
      <div class="shop-tags">
        {entry.data.tags!.map(tag => (
          <span class="shop-tag">{tag}</span>
        ))}
      </div>
    </div>
  )}
</PostLayout>

<style>
  .shop-date {
    font-size: 12px;
    font-weight: 300;
    color: var(--color-text-muted);
    margin: 0.25rem 0 0.75rem;
  }

  .shop-meta {
    display: flex;
    gap: 2rem;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid #D9C9B8;
    padding-top: 1rem;
    padding-bottom: 1.5rem;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .shop-meta-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .shop-meta-label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .shop-meta-value {
    font-size: 13px;
    font-weight: 300;
    color: var(--color-text-primary);
  }

  .shop-tags-footer {
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    margin-top: 2rem;
  }

  .shop-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .shop-tag {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-bg);
    border: 0.5px solid var(--color-border);
    padding: 0.25rem 0.625rem;
    border-radius: 2px;
  }
</style>
